{
    // Evita fixar um interpretador de um SO especifico no repositorio.
    // Cada maquina deve selecionar o proprio .venv local no VS Code.
    "python.analysis.extraPaths": [
        "${workspaceFolder}/ServiceDesk",
        "${workspaceFolder}/ServiceDesk/ServiceDesk"
    ],
    "python.analysis.exclude": [
        "**/venv/**",
        "**/.venv/**"
    ],
    "python.terminal.activateEnvironment": true
}
