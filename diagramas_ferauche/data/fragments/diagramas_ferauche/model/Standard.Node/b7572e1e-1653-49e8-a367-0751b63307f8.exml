      <COMP relation="Descriptor">
        <OBJECT>
          <ID name="" mc="Infrastructure.Note" uid="19dec8a4-3092-4697-ba5d-b411543cd9fc"/>
          <ATTRIBUTES>
            <ATT name="Content"><![CDATA[O servidor Django é um nó dentro do sistema que requer o backend django, serviços internos dos módulos e acesso ao banco de dados, além do módulo de sistema específico para autenticação nativo do django, o django.contrib.auth.]]></ATT>
            <ATT name="MimeType"><![CDATA[text/plain]]></ATT>
            <ATT name="Name"></ATT>
            <ATT name="status">1970354901745664</ATT>
          </ATTRIBUTES>
          <DEPENDENCIES>
