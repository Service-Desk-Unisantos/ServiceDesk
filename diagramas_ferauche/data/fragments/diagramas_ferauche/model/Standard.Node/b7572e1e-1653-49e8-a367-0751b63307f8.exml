                <ATTRIBUTES>
                  <ATT name="Content"><![CDATA[A ligação indica a comunicação de rede que há entre os nós, nesse caso, o servidor requer serviços internos do banco de dados.
]]></ATT>
                  <ATT name="MimeType"><![CDATA[text/plain]]></ATT>
                  <ATT name="Name"></ATT>
                  <ATT name="status">1970354901745664</ATT>
